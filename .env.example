# CPU-only llama.cpp server image (no GPU required).
LMS_IMAGE=ghcr.io/ggml-org/llama.cpp:server

# API ports exposed on host.
LMS_PORT_MODEL1=1234
LMS_PORT_MODEL2=1235

# Preferred and fallback model roots.
LMS_MODELS_ROOT_PRIMARY=/expert_scratch/lmstudio-models
LMS_MODELS_ROOT_FALLBACK=/filer/users/rymax1e/lmstudio-models

# Model subdirectories (autoloaded on startup by start.sh).
LMS_MODEL1_SUBDIR=lmstudio-community/Qwen3.6-35B-A3B-GGUF
LMS_MODEL2_SUBDIR=lmstudio-community/Qwen3-4B-Instruct-2507-GGUF

# Computed by start.sh; keep empty in .env.
LMS_MODEL1_CONTAINER_PATH=
LMS_MODEL2_CONTAINER_PATH=

# Runtime tuning.
LMS_MAX_CONCURRENT=4
LMS_THREADS=16
LMS_CTX_SIZE=200000
LMS_CONTAINER_MAX_RAM=60g
