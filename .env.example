# Port on which lms daemon will listen (OpenAI-compatible REST API)
LMS_PORT=1234
LMS_CONTEXT_LENGTH=262144
LMS_AUTOLOAD=true
# REQUIRED if you have more than one LLM on disk: exact model key from `docker exec lmstudio lms ls --llm`.
# If empty, entrypoint.sh auto-picks from `lms ls` and loads the *first* that succeeds (often a small model, e.g. 7B).
LMS_MODEL=qwen3-coder-30b-a3b-instruct

# Port on which Open WebUI will be available (chat interface for users)
WEBUI_PORT=3000
