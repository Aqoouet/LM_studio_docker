# Port on which lms daemon will listen (OpenAI-compatible REST API)
LMS_PORT=1234
LMS_CONTEXT_LENGTH=262144
LMS_AUTOLOAD=true

# Max concurrent predictions per loaded model (maps to --parallel in lms load)
LMS_MAX_CONCURRENT=10

# Model to download at container startup (if not already on disk)
# Note: Qwen3.6-35B-A3B is Safetensors-only on HF; use GGUF mirror for LM Studio:
#   LMS_GET_MODEL=https://huggingface.co/lmstudio-community/Qwen3.6-35B-A3B-GGUF@q4_k_m
#   (also: @q6_k, @q8_0). After download the key in lms ls --llm is usually qwen3.6-35b-a3b.
LMS_GET_MODEL=qwen/qwen3-4b-2507

# Space-separated list of model keys to autoload at startup.
# Use exact keys from: docker exec lmstudio lms ls --llm
# Note: --mlock is not exposed in lms CLI; no explicit flag available.
LMS_MODELS=qwen/qwen3-4b-2507 qwen3.6-35b-a3b

# Port on which Open WebUI will be available (chat interface for users)
WEBUI_PORT=3000
